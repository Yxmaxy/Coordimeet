FROM python:3.12-alpine3.19

RUN apk add --no-cache gcc musl-dev libffi-dev git && \
    git --version

COPY --from=ghcr.io/astral-sh/uv:0.10.6 /uv /usr/local/bin/uv

WORKDIR /app

COPY pyproject.toml ./
RUN uv sync --no-dev

COPY backend/ ./

ENV PATH="/app/.venv/bin:$PATH"

CMD ["celery", "-A", "example_app", "worker", "-l", "INFO", "-E"]
